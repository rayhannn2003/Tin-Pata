{
  "expo": {
    "name": "Tin Pata",
    "slug": "reading-habit-tracker",
    "version": "1.3.0",
    "orientation": "portrait",
    "icon": "./assets/images/updatedIcon.png",
    "scheme": "tinpata",
    "userInterfaceStyle": "automatic",
    "ios": {
      "supportsTablet": true,
      "bundleIdentifier": "com.readinghabit.tracker"
    },
    "android": {
      "adaptiveIcon": {
        "backgroundColor": "#F8F7F4",
        "foregroundImage": "./assets/images/updatedIcon.png",
        "backgroundImage": "./assets/images/android-icon-background.png",
        "monochromeImage": "./assets/images/updatedIcon.png"
      },
      "package": "com.readinghabit.tracker",
      "permissions": [
        "android.permission.READ_EXTERNAL_STORAGE",
        "android.permission.WRITE_EXTERNAL_STORAGE",
        "android.permission.DOWNLOAD_WITHOUT_NOTIFICATION",
        "android.permission.ACCESS_NETWORK_STATE"
      ]
    },
    "web": {
      "bundler": "metro",
      "output": "static",
      "favicon": "./assets/images/updatedIcon.png"
    },
    "plugins": [
      "expo-router",
      "expo-sqlite",
      "expo-dev-client",
      "expo-brightness",
      "@config-plugins/react-native-blob-util",
      "@config-plugins/react-native-pdf",
      [
        "expo-notifications",
        {
          "icon": "./assets/images/notification-icon.png",
          "color": "#5B8A72"
        }
      ],
      [
        "expo-splash-screen",
        {
          "image": "./assets/images/updatedIcon.png",
          "resizeMode": "contain",
          "backgroundColor": "#F8F7F4",
          "dark": {
            "backgroundColor": "#1C1C1E"
          }
        }
      ]
    ],
    "experiments": {
      "typedRoutes": true
    },
    "extra": {
      "router": {},
      "eas": {
        "projectId": "8b647e44-ec37-4cd3-ae00-3f69ab399674"
      }
    }
  }
}
